# Copy this file to .env.local (or export these before running `pnpm dev`)

# Required to boot
PORT=5000

# Postgres connection (required for any DB-backed route: /api/loops, /api/trips, etc.)
# Local example if you run Postgres via Docker (see LOCAL_SETUP.md):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/move_apayao

# Optional — Redis powers live driver location (geo) features.
# If unset, the server still boots; Redis-backed routes become no-ops.
REDIS_URL=redis://localhost:6379

# Required for auth (Supabase project settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional integrations
OPENWEATHERMAP_API_KEY=
READER_API_KEY=

# Comma-separated list of origins allowed to call this API (dashboard, mobile
# web build, etc). Required in production — CORS is denied by default when
# unset, rather than reflecting any origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Tuning (optional, sane defaults applied if unset)
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=10000

LOG_LEVEL=info
