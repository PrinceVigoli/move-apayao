{
  "expo": {
    "name": "MOVE Apayao Driver",
    "slug": "driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "moveapayaodriver",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.moveapayao.driver",
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ]
      },
      "config": {
        "googleMapsApiKey": "AIzaSyAUCqrFbE1Y1jqbKqq2aUp4kfCCpTWNcok"
      }
    },
    "android": {
      "package": "com.moveapayao.driver",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAUCqrFbE1Y1jqbKqq2aUp4kfCCpTWNcok"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-dev-client",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MOVE Apayao Driver uses your location to broadcast your position to nearby passengers and match you with ride requests.",
          "locationWhenInUsePermission": "MOVE Apayao Driver uses your location to broadcast your position to nearby passengers and match you with ride requests.",
          "isAndroidForegroundServiceEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "53adf49c-d688-4cea-9eda-8aff2cb6ca6d"
      }
    },
    "owner": "keypass123"
  }
}
